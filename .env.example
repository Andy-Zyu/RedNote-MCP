# RedNote MCP Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# Required: PigBun AI API Key
PIGBUN_API_KEY=pb_live_your_api_key_here

# Optional: Matrix Web API port (default: 3001)
MATRIX_PORT=3001

# Optional: noVNC port for remote QR code scanning (default: 6080)
NOVNC_PORT=6080

# Optional: Enable VNC for remote browser viewing (default: true)
ENABLE_VNC=true
