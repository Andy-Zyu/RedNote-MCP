FROM node:22-alpine

WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci --omit=dev

# Copy built files
COPY dist ./dist
COPY openclaw.plugin.json ./

# Lightweight MCP Server: connects to Browser Manager via HTTP,
# does NOT launch any browser instances itself.
CMD ["node", "dist/cli.js", "--stdio"]
